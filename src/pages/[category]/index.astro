---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import CalibrationBar from "../../components/core/CalibrationBar.astro";
import ObjectCard from "../../components/core/ObjectCard.astro";
import BreadcrumbNav from "../../components/seo/BreadcrumbNav.astro";
import { getCategoryPaths } from "../../lib/objectUtils";
import { getCategoryPageTitle, getCategoryCanonicalUrl, buildCategoryJsonLd } from "../../lib/seo";
import type { Category, ActualSizeObject } from "../../data/schema";

export async function getStaticPaths() {
  return getCategoryPaths();
}

interface Props {
  category: Category;
  objects: ActualSizeObject[];
}

const { category, objects } = Astro.props;

const title = getCategoryPageTitle(category);
const canonicalUrl = getCategoryCanonicalUrl(category);
const jsonLd = buildCategoryJsonLd(category, canonicalUrl);

const breadcrumbs = [
  { name: "Home", href: "/" },
  { name: category.name, href: `/${category.slug}` },
];
---

<BaseLayout
  title={title}
  description={category.metaDescription}
  canonical={canonicalUrl}
  jsonLd={jsonLd}
>
  <CalibrationBar />

  <div class="cat-page">
    <div class="container">

      <div class="cat-page__breadcrumb">
        <BreadcrumbNav crumbs={breadcrumbs} />
      </div>

      <header class="cat-page__header">
        <span class="cat-page__icon" aria-hidden="true">{category.icon}</span>
        <div>
          <h1 class="cat-page__title">{category.name} at Actual Size</h1>
          <p class="cat-page__desc">{category.description}</p>
        </div>
      </header>

      <div class="cat-page__count">
        <span>{objects.length} object{objects.length !== 1 ? "s" : ""}</span>
      </div>

      <!-- Object grid -->
      {objects.length > 0 ? (
        <section class="cat-page__grid" aria-label={`${category.name} objects`}>
          <div class="objects-grid">
            {objects.map((obj) => (
              <ObjectCard object={obj} />
            ))}
          </div>
        </section>
      ) : (
        <p class="cat-page__empty">No objects in this category yet. Check back soon.</p>
      )}

      <!-- SEO content -->
      <section class="cat-page__seo">
        <h2>{category.metaTitle}</h2>
        <p>{category.metaDescription}</p>
        <p>
          All objects on this page are displayed at their true physical size after calibration.
          <a href="/calibration">How to calibrate your screen →</a>
        </p>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .cat-page {
    padding: 28px 0 80px;
  }

  .cat-page__breadcrumb {
    margin-bottom: 28px;
  }

  .cat-page__header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 32px;
  }

  .cat-page__icon {
    font-size: 3rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .cat-page__title {
    margin-bottom: 8px;
  }

  .cat-page__desc {
    font-size: 1rem;
    max-width: 560px;
  }

  .cat-page__count {
    font-size: 0.82rem;
    color: hsl(var(--text-secondary-hsl));
    margin-bottom: 24px;
    font-weight: 500;
  }

  .cat-page__grid {
    margin-bottom: 60px;
  }

  .cat-page__empty {
    padding: 40px 0;
    text-align: center;
    color: hsl(var(--text-secondary-hsl));
  }

  .cat-page__seo {
    border-top: 1px solid hsl(var(--border-color-hsl));
    padding-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 700px;
  }

  .cat-page__seo h2 {
    font-size: 1.3rem;
  }
</style>
