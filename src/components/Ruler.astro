---
// Ruler.astro - High Precision Actual Size Online Ruler
---

<div class="ruler-app-container">
  <!-- Controls Bar -->
  <div class="ruler-controls glass">
    <div class="control-group">
      <span class="control-label">Unit:</span>
      <div class="btn-group" id="unit-btn-group">
        <button class="control-btn active" data-unit="cm">cm</button>
        <button class="control-btn" data-unit="mm">mm</button>
        <button class="control-btn" data-unit="in">inch</button>
        <button class="control-btn" data-unit="px">px</button>
      </div>
      
      <!-- Fractional toggle (only shown when unit is inch) -->
      <label class="fraction-toggle-wrapper hidden" id="fraction-toggle-container">
        <input type="checkbox" id="fraction-toggle" />
        <span class="toggle-label">Fractions (1/16)</span>
      </label>
    </div>

    <div class="control-group">
      <button class="action-btn active-shrink" id="calibrate-btn">
        <span class="icon">⚙️</span> Calibrate Screen
      </button>
      <button class="action-btn active-shrink" id="lock-btn">
        <span class="icon" id="lock-icon">🔓</span> <span id="lock-text">Lock</span>
      </button>
      <button class="action-btn active-shrink" id="fullscreen-btn">
        <span class="icon">🖥️</span> Fullscreen
      </button>
      <button class="action-btn active-shrink" id="reset-btn">
        Reset
      </button>
    </div>
  </div>

  <!-- Calibration Info Bar -->
  <div class="calibration-info-bar">
    <span>DPI Calibrated to: <strong id="dpi-display">96</strong> PPI</span>
    <span class="bullet">&bull;</span>
    <span>Auto-detected: <span id="device-detect">Default (Desktop)</span></span>
  </div>

  <!-- Interactive Workspace Canvas -->
  <div class="workspace-viewport" id="workspace">
    
    <!-- Drag Instructions Overlay -->
    <div class="drag-instructions" id="drag-instructions">
      <p>🖱️ Drag Rulers to Position &bull; Use Caliper lines to measure exact boundaries &bull; Press <strong>L</strong> to lock</p>
    </div>

    <!-- Horizontal Ruler -->
    <div class="ruler-container horizontal" id="ruler-h-container" style="top: 80px; left: 40px;">
      <div class="ruler-drag-handle horizontal-drag-handle" title="Drag Ruler">
        <span class="drag-dots">⋮⋮</span>
      </div>
      <canvas id="ruler-h-canvas"></canvas>
      <!-- Caliper line EW -->
      <div class="caliper-line vertical-caliper" id="caliper-h">
        <div class="caliper-handle">
          <span class="arrow-lr">↔</span>
        </div>
        <div class="caliper-readout" id="caliper-h-readout">0.00 cm</div>
      </div>
    </div>

    <!-- Vertical Ruler -->
    <div class="ruler-container vertical" id="ruler-v-container" style="top: 200px; left: 40px;">
      <div class="ruler-drag-handle vertical-drag-handle" title="Drag Ruler">
        <span class="drag-dots">⋯⋯</span>
      </div>
      <canvas id="ruler-v-canvas"></canvas>
      <!-- Caliper line NS -->
      <div class="caliper-line horizontal-caliper" id="caliper-v">
        <div class="caliper-handle">
          <span class="arrow-ud">↕</span>
        </div>
        <div class="caliper-readout" id="caliper-v-readout">0.00 cm</div>
      </div>
    </div>

  </div>

  <!-- Calibration Modal Overlay -->
  <div class="modal-overlay" id="calibration-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Screen Calibration Wizard</h3>
        <button class="modal-close" id="modal-close-btn">&times;</button>
      </div>

      <!-- Tab selectors -->
      <div class="modal-tabs">
        <button class="tab-btn active" data-tab="card-tab">Credit Card</button>
        <button class="tab-btn" data-tab="screen-tab">Manual Size</button>
        <button class="tab-btn" data-tab="ppi-tab">Manual PPI</button>
      </div>

      <!-- Tab 1: Credit Card Sizing -->
      <div class="tab-panel active" id="card-tab">
        <p class="tab-desc">Place a physical credit card, debit card, or ID against your screen. Drag the slider below until the blue virtual card outlines exactly match your physical card's physical width.</p>
        
        <div class="card-visual-wrapper">
          <div class="card-outline" id="virtual-card">
            <div class="card-chip"></div>
            <div class="card-logo">💳</div>
          </div>
        </div>

        <div class="slider-group">
          <label for="card-slider">Adjust card size:</label>
          <input type="range" id="card-slider" min="200" max="600" value="323" class="slider-control" />
          <div class="slider-stats">
            <span id="slider-pixel-val">323 pixels</span>
          </div>
        </div>
      </div>

      <!-- Tab 2: Manual Screen Size Entry -->
      <div class="tab-panel" id="screen-tab">
        <p class="tab-desc">Enter your physical monitor diagonal size in inches, and your current desktop resolution below to compute actual physical pixels.</p>
        
        <div class="input-grid">
          <div class="input-item">
            <label for="monitor-diagonal">Diagonal Size (inches)</label>
            <input type="number" id="monitor-diagonal" value="15.6" step="0.1" min="3" class="input-control" />
          </div>
          <div class="input-item">
            <label for="res-width">Screen Width (pixels)</label>
            <input type="number" id="res-width" value="1920" class="input-control" />
          </div>
          <div class="input-item">
            <label for="res-height">Screen Height (pixels)</label>
            <input type="number" id="res-height" value="1080" class="input-control" />
          </div>
        </div>

        <button class="action-btn primary-btn btn-full" id="calc-diagonal-btn">Apply Specifications</button>
      </div>

      <!-- Tab 3: Manual PPI -->
      <div class="tab-panel" id="ppi-tab">
        <p class="tab-desc">If you know your exact monitor Pixels Per Inch (PPI) or Dot Pitch, enter it directly below.</p>
        <div class="input-group-row">
          <input type="number" id="manual-ppi-input" value="96" min="30" max="600" class="input-control" />
          <button class="action-btn primary-btn" id="apply-ppi-btn">Apply PPI</button>
        </div>
      </div>

      <div class="modal-footer">
        <button class="action-btn secondary-btn" id="save-close-btn">Save & Close</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* App Outer Container */
  .ruler-app-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-top: 10px;
  }

  /* Controls layout */
  .ruler-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-radius: var(--radius-md);
    margin-bottom: 8px;
    flex-wrap: wrap;
    gap: 16px;
    box-shadow: var(--shadow-sm);
  }

  .control-group {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .control-label {
    font-weight: 700;
    font-size: 0.95rem;
    color: hsl(var(--text-secondary-hsl));
  }

  /* Buttons */
  .btn-group {
    display: flex;
    background-color: hsla(var(--border-color-hsl), 0.3);
    border-radius: var(--radius-sm);
    padding: 3px;
    border: 1px solid hsl(var(--border-color-hsl));
  }

  .control-btn {
    padding: 6px 16px;
    border-radius: calc(var(--radius-sm) - 2px);
    font-weight: 600;
    font-size: 0.9rem;
    color: hsl(var(--text-secondary-hsl));
    transition: var(--transition-quick);
  }

  .control-btn:hover {
    color: hsl(var(--text-primary-hsl));
  }

  .control-btn.active {
    background-color: hsl(var(--bg-secondary-hsl));
    color: hsl(var(--accent-hsl));
    box-shadow: var(--shadow-sm);
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background-color: hsl(var(--bg-secondary-hsl));
    border: 1px solid hsl(var(--border-color-hsl));
    border-radius: var(--radius-sm);
    color: hsl(var(--text-primary-hsl));
    font-weight: 600;
    font-size: 0.9rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-quick);
  }

  .action-btn:hover {
    background-color: hsla(var(--border-color-hsl), 0.25);
    border-color: hsl(var(--text-secondary-hsl));
  }

  .action-btn.active {
    background: var(--accent-gradient);
    color: white;
    border-color: transparent;
  }

  .primary-btn {
    background: var(--accent-gradient);
    color: white !important;
    border: none;
  }

  .primary-btn:hover {
    opacity: 0.9;
  }

  .secondary-btn {
    background-color: hsla(var(--border-color-hsl), 0.2);
  }

  .btn-full {
    width: 100%;
    justify-content: center;
    margin-top: 10px;
  }

  /* Fraction checkbox styling */
  .fraction-toggle-wrapper {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: hsl(var(--text-secondary-hsl));
    user-select: none;
  }

  .fraction-toggle-wrapper.hidden {
    display: none;
  }

  /* Calibration Info */
  .calibration-info-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 24px;
    font-size: 0.8rem;
    color: hsl(var(--text-secondary-hsl));
  }

  .bullet {
    color: hsl(var(--border-color-hsl));
  }

  /* Workspace Viewport */
  .workspace-viewport {
    position: relative;
    width: 100%;
    height: 600px;
    background-color: hsla(var(--bg-secondary-hsl), 0.4);
    border: 1px solid hsl(var(--border-color-hsl));
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 24px;
    user-select: none;
    box-shadow: var(--shadow-sm);
  }

  .workspace-viewport.locked {
    cursor: not-allowed;
  }

  /* Instructions overlay */
  .drag-instructions {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    background-color: hsla(var(--bg-secondary-hsl), 0.85);
    backdrop-filter: blur(4px);
    border: 1px solid hsl(var(--border-color-hsl));
    border-radius: 100px;
    padding: 6px 18px;
    font-size: 0.8rem;
    font-weight: 550;
    color: hsl(var(--text-secondary-hsl));
    pointer-events: none;
    box-shadow: var(--shadow-sm);
    text-align: center;
    width: 90%;
    max-width: 580px;
  }

  /* Ruler Container Structure */
  .ruler-container {
    position: absolute;
    display: flex;
    background-color: hsl(var(--bg-secondary-hsl));
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    z-index: 20;
    touch-action: none;
    border: 1px solid hsl(var(--border-color-hsl));
    transition: box-shadow var(--transition-quick);
  }

  .ruler-container:active {
    box-shadow: var(--shadow-lg);
  }

  .ruler-container.horizontal {
    flex-direction: row;
    height: 70px;
    min-width: 300px;
    width: 80%;
  }

  .ruler-container.vertical {
    flex-direction: column;
    width: 70px;
    min-height: 300px;
    height: 70%;
  }

  .workspace-viewport.locked .ruler-container {
    box-shadow: var(--shadow-sm) !important;
  }

  /* Drag handles */
  .ruler-drag-handle {
    background-color: hsla(var(--border-color-hsl), 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    color: hsl(var(--text-secondary-hsl));
    cursor: move;
    user-select: none;
    font-weight: 900;
    transition: var(--transition-quick);
  }

  .ruler-drag-handle:hover {
    background-color: hsla(var(--border-color-hsl), 0.6);
    color: hsl(var(--text-primary-hsl));
  }

  .workspace-viewport.locked .ruler-drag-handle {
    cursor: not-allowed;
    background-color: transparent !important;
    opacity: 0.2;
  }

  .horizontal-drag-handle {
    width: 32px;
    height: 100%;
    border-right: 1px solid hsl(var(--border-color-hsl));
    border-top-left-radius: inherit;
    border-bottom-left-radius: inherit;
  }

  .vertical-drag-handle {
    height: 32px;
    width: 100%;
    border-bottom: 1px solid hsl(var(--border-color-hsl));
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
  }

  .drag-dots {
    opacity: 0.6;
    letter-spacing: -0.05em;
  }

  canvas {
    display: block;
    flex-grow: 1;
  }

  /* Calipers / Measurement Lines */
  .caliper-line {
    position: absolute;
    background-color: hsl(var(--accent-hsl));
    z-index: 30;
    touch-action: none;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .vertical-caliper {
    width: 2px;
    height: 100%;
    cursor: ew-resize;
    top: 0;
    left: 200px; /* Initial distance */
    border-left: 1px solid rgba(255, 255, 255, 0.4);
    border-right: 1px solid rgba(255, 255, 255, 0.4);
  }

  .horizontal-caliper {
    height: 2px;
    width: 100%;
    cursor: ns-resize;
    left: 0;
    top: 200px; /* Initial distance */
    border-top: 1px solid rgba(255, 255, 255, 0.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
  }

  .workspace-viewport.locked .caliper-line {
    pointer-events: none; /* Calipers can't be dragged when locked */
    opacity: 0.8;
  }

  .caliper-handle {
    position: absolute;
    width: 28px;
    height: 28px;
    background-color: hsl(var(--accent-hsl));
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: bold;
    box-shadow: var(--shadow-md);
    transition: var(--transition-quick);
  }

  .caliper-handle:hover {
    transform: scale(1.1);
  }

  .vertical-caliper .caliper-handle {
    bottom: -14px;
  }

  .horizontal-caliper .caliper-handle {
    right: -14px;
  }

  .caliper-readout {
    position: absolute;
    background-color: hsl(var(--text-primary-hsl));
    color: hsl(var(--bg-secondary-hsl));
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
    pointer-events: none;
  }

  .vertical-caliper .caliper-readout {
    bottom: 20px;
  }

  .horizontal-caliper .caliper-readout {
    right: 20px;
  }

  /* Calibration Wizard Modal Styling */
  .modal-tabs {
    display: flex;
    border-bottom: 1px solid hsl(var(--border-color-hsl));
    margin-bottom: 20px;
  }

  .tab-btn {
    padding: 8px 16px;
    font-weight: 600;
    color: hsl(var(--text-secondary-hsl));
    border-bottom: 2px solid transparent;
    transition: var(--transition-quick);
  }

  .tab-btn:hover {
    color: hsl(var(--text-primary-hsl));
  }

  .tab-btn.active {
    color: hsl(var(--accent-hsl));
    border-bottom-color: hsl(var(--accent-hsl));
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .tab-desc {
    font-size: 0.85rem;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  /* Card Visual Grid */
  .card-visual-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: hsla(var(--border-color-hsl), 0.15);
    border: 1px solid hsl(var(--border-color-hsl));
    border-radius: var(--radius-sm);
    padding: 30px;
    margin-bottom: 20px;
    height: 220px;
    overflow: hidden;
  }

  .card-outline {
    width: 323px; /* Default width in px corresponding to card width at ~96 PPI */
    height: 204px; /* Maintain standard ISO card aspect ratio (85.6 / 53.98) ~ 1.585 */
    border: 2px solid hsl(var(--accent-hsl));
    background-color: hsla(var(--accent-hsl), 0.05);
    border-radius: 12px;
    position: relative;
    box-shadow: 0 8px 32px hsla(var(--accent-hsl), 0.15);
    transition: background-color var(--transition-smooth);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px;
  }

  .card-chip {
    width: 40px;
    height: 30px;
    background: linear-gradient(135deg, #ffd700, #daa520);
    border-radius: 6px;
    opacity: 0.8;
  }

  .card-logo {
    align-self: flex-end;
    font-size: 1.5rem;
  }

  .slider-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .slider-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: hsl(var(--text-secondary-hsl));
  }

  .slider-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    font-weight: 700;
    color: hsl(var(--accent-hsl));
  }

  /* Manual entry forms */
  .input-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }

  .input-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .input-item label {
    font-size: 0.8rem;
    font-weight: 600;
    color: hsl(var(--text-secondary-hsl));
  }

  .input-control {
    padding: 10px;
    border: 1px solid hsl(var(--border-color-hsl));
    border-radius: var(--radius-sm);
    background-color: hsl(var(--bg-secondary-hsl));
    color: hsl(var(--text-primary-hsl));
    font-size: 0.95rem;
    width: 100%;
    transition: var(--transition-quick);
  }

  .input-control:focus {
    outline: none;
    border-color: hsl(var(--accent-hsl));
    box-shadow: 0 0 0 3px hsla(var(--accent-hsl), 0.15);
  }

  .input-group-row {
    display: flex;
    gap: 12px;
  }

  .input-group-row input {
    flex-grow: 1;
  }

  .modal-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid hsl(var(--border-color-hsl));
  }

  /* Media Adjustments */
  @media (max-width: 768px) {
    .ruler-controls {
      padding: 12px;
    }
    .workspace-viewport {
      height: 480px;
    }
    .ruler-container.horizontal {
      width: 90%;
      left: 10px !important;
    }
    .ruler-container.vertical {
      height: 80%;
      top: 40px !important;
      left: 10px !important;
    }
    .drag-instructions {
      display: none; /* Hide on small screens to save vertical space */
    }
  }
</style>

<script>
  // Dynamic client controller for drawing scale ticks & positioning elements
  
  // Standard card dimension
  const CARD_WIDTH_INCH = 3.370;
  
  // Known Device PPI dictionary for auto detection
  const DEVICE_DPI_DICT: { [key: string]: number } = {
    "iphone": 460,
    "ipad": 264,
    "ipod": 326,
    "macintosh": 128, // generic retina average zoom scale
    "android": 360,   // general phone scaling average
    "samsung": 400,
    "pixel": 440
  };

  // State Management
  let ppi = 96; // default pixels per inch
  let unit = "cm";
  let showFractions = false;
  let locked = false;

  // Select DOM Nodes
  const dpiDisplay = document.getElementById("dpi-display");
  const deviceDetectSpan = document.getElementById("device-detect");
  const unitBtnGroup = document.getElementById("unit-btn-group");
  const fractionToggleContainer = document.getElementById("fraction-toggle-container");
  const fractionToggle = document.getElementById("fraction-toggle") as HTMLInputElement;
  const lockBtn = document.getElementById("lock-btn");
  const lockIcon = document.getElementById("lock-icon");
  const lockText = document.getElementById("lock-text");
  const fullscreenBtn = document.getElementById("fullscreen-btn");
  const resetBtn = document.getElementById("reset-btn");
  const calibrateBtn = document.getElementById("calibrate-btn");
  const workspace = document.getElementById("workspace");
  const dragInstructions = document.getElementById("drag-instructions");

  // Rulers
  const rulerHContainer = document.getElementById("ruler-h-container") as HTMLDivElement;
  const rulerVContainer = document.getElementById("ruler-v-container") as HTMLDivElement;
  const rulerHCanvas = document.getElementById("ruler-h-canvas") as HTMLCanvasElement;
  const rulerVCanvas = document.getElementById("ruler-v-canvas") as HTMLCanvasElement;

  // Calipers
  const caliperH = document.getElementById("caliper-h") as HTMLDivElement;
  const caliperV = document.getElementById("caliper-v") as HTMLDivElement;
  const caliperHReadout = document.getElementById("caliper-h-readout");
  const caliperVReadout = document.getElementById("caliper-v-readout");

  // Modal Sizing Elements
  const modal = document.getElementById("calibration-modal");
  const modalCloseBtn = document.getElementById("modal-close-btn");
  const saveCloseBtn = document.getElementById("save-close-btn");
  const cardSlider = document.getElementById("card-slider") as HTMLInputElement;
  const sliderPixelVal = document.getElementById("slider-pixel-val");
  const virtualCard = document.getElementById("virtual-card") as HTMLDivElement;
  
  // Manual specs forms
  const diagonalInput = document.getElementById("monitor-diagonal") as HTMLInputElement;
  const resWidthInput = document.getElementById("res-width") as HTMLInputElement;
  const resHeightInput = document.getElementById("res-height") as HTMLInputElement;
  const calcDiagonalBtn = document.getElementById("calc-diagonal-btn");
  const manualPpiInput = document.getElementById("manual-ppi-input") as HTMLInputElement;
  const applyPpiBtn = document.getElementById("apply-ppi-btn");

  // Load Saved Preferences
  function loadSettings() {
    // Check localStorage
    if (localStorage.getItem("ruler_ppi")) {
      ppi = parseFloat(localStorage.getItem("ruler_ppi") || "96");
    } else {
      // Auto-detect based on user agent
      autoDetectDevice();
    }
    
    if (localStorage.getItem("ruler_unit")) {
      unit = localStorage.getItem("ruler_unit") || "cm";
    }

    if (localStorage.getItem("ruler_fractions")) {
      showFractions = localStorage.getItem("ruler_fractions") === "true";
      if (fractionToggle) fractionToggle.checked = showFractions;
    }

    updateUIState();
    triggerRedraw();
  }

  // Save PPI to localStorage
  function savePPI(newPpi: number) {
    ppi = Math.round(newPpi * 100) / 100;
    localStorage.setItem("ruler_ppi", ppi.toString());
    if (dpiDisplay) dpiDisplay.textContent = ppi.toString();
    (document.getElementById("manual-ppi-input") as HTMLInputElement).value = Math.round(ppi).toString();
    triggerRedraw();
    updateCaliperCalculations();
  }

  // Update UI Selectors based on active state variables
  function updateUIState() {
    if (dpiDisplay) dpiDisplay.textContent = ppi.toString();

    // Set Active Unit Button
    if (unitBtnGroup) {
      const buttons = unitBtnGroup.querySelectorAll("button");
      buttons.forEach(btn => {
        if (btn.getAttribute("data-unit") === unit) {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });
    }

    // Toggle Fraction Box visibility
    if (fractionToggleContainer) {
      if (unit === "in") {
        fractionToggleContainer.classList.remove("hidden");
      } else {
        fractionToggleContainer.classList.add("hidden");
      }
    }
  }

  // Perform Device User Agent Detection
  function autoDetectDevice() {
    const ua = navigator.userAgent.toLowerCase();
    let detectedName = "Generic Screen";
    let detectedPpi = 96; // fallback desktop

    for (const key in DEVICE_DPI_DICT) {
      if (ua.indexOf(key) !== -1) {
        detectedPpi = DEVICE_DPI_DICT[key];
        detectedName = key.charAt(0).toUpperCase() + key.slice(1);
        break;
      }
    }

    // Check if touch device is present
    const isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
    if (isTouch && detectedPpi === 96) {
      detectedPpi = 160; // general android mobile/tablet fallback
      detectedName = "Generic Mobile";
    }

    if (deviceDetectSpan) deviceDetectSpan.textContent = detectedName;
    ppi = detectedPpi;
    localStorage.setItem("ruler_ppi", ppi.toString());
  }

  // Draw Scales dynamically on canvases
  function drawRuler(canvas: HTMLCanvasElement, isVertical: boolean) {
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const rect = canvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;

    // Set dynamic high-res resolutions
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);

    // Clear Canvas
    ctx.clearRect(0, 0, rect.width, rect.height);

    // Get current theme color configurations
    const isDark = document.documentElement.classList.contains("dark");
    const textColor = isDark ? "#e2e8f0" : "#0f172a";
    const tickColor = isDark ? "rgba(226, 232, 240, 0.45)" : "rgba(15, 23, 42, 0.35)";
    const majorTickColor = isDark ? "rgba(226, 232, 240, 0.85)" : "rgba(15, 23, 42, 0.8)";
    const accentColor = "#4f46e5"; // Indigo default

    ctx.font = "600 10px system-ui, sans-serif";
    ctx.fillStyle = textColor;
    ctx.strokeStyle = tickColor;
    ctx.lineWidth = 1;

    // Conversions
    // ppi = pixels per inch. 1 inch = ppi pixels.
    // 1 cm = ppi / 2.54 pixels.
    // 1 mm = ppi / 25.4 pixels.
    let pxPerUnit = 1;
    let labelInterval = 10;
    let tickSubdivisions = 10; // e.g. 10 ticks per unit

    if (unit === "px") {
      pxPerUnit = 1;
      labelInterval = 50;
      tickSubdivisions = 10;
    } else if (unit === "cm") {
      pxPerUnit = ppi / 2.54;
      labelInterval = 1; // label every cm
      tickSubdivisions = 10; // sub-ticks every mm (0.1 cm)
    } else if (unit === "mm") {
      pxPerUnit = ppi / 25.4;
      labelInterval = 10; // label every 10mm (1 cm)
      tickSubdivisions = 10; // sub-ticks every mm
    } else if (unit === "in") {
      pxPerUnit = ppi;
      labelInterval = 1; // label every inch
      tickSubdivisions = showFractions ? 16 : 10; // 16th increments or 10th decimal
    }

    const totalLength = isVertical ? rect.height : rect.width;
    const thickness = isVertical ? rect.width : rect.height;

    // Start drawing ticks
    if (unit === "in" && showFractions) {
      // Draw standard English Imperial fractional ticks (1/16ths)
      const inchesCount = Math.ceil(totalLength / ppi);
      for (let i = 0; i <= inchesCount * 16; i++) {
        const pxOffset = (i / 16) * ppi;
        if (pxOffset > totalLength) break;

        let tickHeight = 6;
        let isLabel = false;

        if (i % 16 === 0) {
          tickHeight = 22; // whole inch
          isLabel = true;
        } else if (i % 8 === 0) {
          tickHeight = 16; // 1/2 inch
        } else if (i % 4 === 0) {
          tickHeight = 12; // 1/4 inch
        } else if (i % 2 === 0) {
          tickHeight = 9;  // 1/8 inch
        }

        ctx.strokeStyle = isLabel ? majorTickColor : tickColor;
        ctx.beginPath();
        if (isVertical) {
          ctx.moveTo(thickness, pxOffset);
          ctx.lineTo(thickness - tickHeight, pxOffset);
        } else {
          ctx.moveTo(pxOffset, thickness);
          ctx.lineTo(pxOffset, thickness - tickHeight);
        }
        ctx.stroke();

        // Labels
        if (isLabel && i > 0) {
          const val = i / 16;
          ctx.fillStyle = textColor;
          if (isVertical) {
            ctx.fillText(val.toString(), thickness - 34, pxOffset + 3.5);
          } else {
            ctx.textAlign = "center";
            ctx.fillText(val.toString(), pxOffset, thickness - 26);
          }
        }
      }
    } else {
      // Decimal or metric drawing loops
      const maxUnits = Math.ceil(totalLength / pxPerUnit);
      
      for (let u = 0; u <= maxUnits * tickSubdivisions; u++) {
        const value = u / tickSubdivisions;
        const pxOffset = value * pxPerUnit;
        if (pxOffset > totalLength) break;

        let tickHeight = 6;
        let isLabel = false;

        // Check subdivision styling
        if (u % tickSubdivisions === 0) {
          // Check if we need to print label
          if (Math.round(value) % labelInterval === 0) {
            tickHeight = 20;
            isLabel = true;
          } else {
            tickHeight = 14;
          }
        } else if (u % (tickSubdivisions / 2) === 0) {
          tickHeight = 11; // middle scale tick (e.g. 0.5 cm or 5 mm)
        }

        ctx.strokeStyle = isLabel ? majorTickColor : tickColor;
        ctx.beginPath();
        if (isVertical) {
          ctx.moveTo(thickness, pxOffset);
          ctx.lineTo(thickness - tickHeight, pxOffset);
        } else {
          ctx.moveTo(pxOffset, thickness);
          ctx.lineTo(pxOffset, thickness - tickHeight);
        }
        ctx.stroke();

        // Draw Numerical Labels
        if (isLabel && u > 0) {
          const valLabel = Math.round(value).toString();
          ctx.fillStyle = textColor;
          if (isVertical) {
            ctx.fillText(valLabel, thickness - 32, pxOffset + 3.5);
          } else {
            ctx.textAlign = "center";
            ctx.fillText(valLabel, pxOffset, thickness - 24);
          }
        }
      }
    }

    // Draw baseline border stroke
    ctx.strokeStyle = majorTickColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    if (isVertical) {
      ctx.moveTo(thickness - 0.5, 0);
      ctx.lineTo(thickness - 0.5, rect.height);
    } else {
      ctx.moveTo(0, thickness - 0.5);
      ctx.lineTo(rect.width, thickness - 0.5);
    }
    ctx.stroke();
  }

  // Trigger repaint on both canvasses
  function triggerRedraw() {
    drawRuler(rulerHCanvas, false);
    drawRuler(rulerVCanvas, true);
  }

  // Dragging Functionality for Rulers
  function initDragHandlers() {
    let activeDragElement: HTMLDivElement | null = null;
    let dragStartX = 0;
    let dragStartY = 0;
    let elementStartX = 0;
    let elementStartY = 0;

    // Handles mouse and touch start
    function onPointerDown(e: MouseEvent | TouchEvent, container: HTMLDivElement) {
      if (locked) return;
      activeDragElement = container;

      // Bring to front
      rulerHContainer.style.zIndex = "20";
      rulerVContainer.style.zIndex = "20";
      container.style.zIndex = "25";

      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;

      dragStartX = clientX;
      dragStartY = clientY;
      elementStartX = parseInt(container.style.left) || 0;
      elementStartY = parseInt(container.style.top) || 0;

      // Add document level listeners for smooth dragging outside element bounds
      document.addEventListener("mousemove", onPointerMove);
      document.addEventListener("touchmove", onPointerMove, { passive: false });
      document.addEventListener("mouseup", onPointerUp);
      document.addEventListener("touchend", onPointerUp);
    }

    function onPointerMove(e: MouseEvent | TouchEvent) {
      if (!activeDragElement || locked) return;

      // Prevent scrolling on mobile during dragging
      if (e.cancelable) e.preventDefault();

      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;

      const deltaX = clientX - dragStartX;
      const deltaY = clientY - dragStartY;

      let newLeft = elementStartX + deltaX;
      let newTop = elementStartY + deltaY;

      // Bound constraints (keep at least 40px of ruler visible inside workspace viewport)
      const wsRect = workspace?.getBoundingClientRect();
      const elRect = activeDragElement.getBoundingClientRect();
      
      if (wsRect) {
        const minLeft = -elRect.width + 40;
        const maxLeft = wsRect.width - 40;
        const minTop = -elRect.height + 40;
        const maxTop = wsRect.height - 40;

        newLeft = Math.max(minLeft, Math.min(newLeft, maxLeft));
        newTop = Math.max(minTop, Math.min(newTop, maxTop));
      }

      activeDragElement.style.left = `${newLeft}px`;
      activeDragElement.style.top = `${newTop}px`;
    }

    function onPointerUp() {
      activeDragElement = null;
      document.removeEventListener("mousemove", onPointerMove);
      document.removeEventListener("touchmove", onPointerMove);
      document.removeEventListener("mouseup", onPointerUp);
      document.removeEventListener("touchend", onPointerUp);
    }

    // Attach to drag handles
    const hHandle = rulerHContainer.querySelector(".ruler-drag-handle");
    const vHandle = rulerVContainer.querySelector(".ruler-drag-handle");

    if (hHandle) {
      hHandle.addEventListener("mousedown", (e) => onPointerDown(e as MouseEvent, rulerHContainer));
      hHandle.addEventListener("touchstart", (e) => onPointerDown(e as TouchEvent, rulerHContainer), { passive: true });
    }

    if (vHandle) {
      vHandle.addEventListener("mousedown", (e) => onPointerDown(e as MouseEvent, rulerVContainer));
      vHandle.addEventListener("touchstart", (e) => onPointerDown(e as TouchEvent, rulerVContainer), { passive: true });
    }
  }

  // Draggable Caliper Lines
  function initCaliperHandlers() {
    function setupCaliper(caliper: HTMLDivElement, isVerticalCaliper: boolean, container: HTMLDivElement, readout: HTMLElement | null) {
      const handle = caliper.querySelector(".caliper-handle");
      if (!handle) return;

      let caliperDragStart = 0;
      let caliperStartPos = 0;

      function onCaliperDown(e: MouseEvent | TouchEvent) {
        if (locked) return;
        e.stopPropagation(); // Avoid triggering ruler dragging

        const clientPos = 'touches' in e 
          ? (isVerticalCaliper ? e.touches[0].clientX : e.touches[0].clientY)
          : (isVerticalCaliper ? e.clientX : e.clientY);

        caliperDragStart = clientPos;
        caliperStartPos = isVerticalCaliper ? parseInt(caliper.style.left) || 0 : parseInt(caliper.style.top) || 0;

        document.addEventListener("mousemove", onCaliperMove);
        document.addEventListener("touchmove", onCaliperMove, { passive: false });
        document.addEventListener("mouseup", onCaliperUp);
        document.addEventListener("touchend", onCaliperUp);
      }

      function onCaliperMove(e: MouseEvent | TouchEvent) {
        if (locked) return;
        if (e.cancelable) e.preventDefault();

        const clientPos = 'touches' in e 
          ? (isVerticalCaliper ? e.touches[0].clientX : e.touches[0].clientY)
          : (isVerticalCaliper ? e.clientX : e.clientY);

        const delta = clientPos - caliperDragStart;
        let newPos = caliperStartPos + delta;

        // Constraint check (within ruler container width/height minus drag handle)
        const containerRect = container.getBoundingClientRect();
        const startBound = isVerticalCaliper ? 32 : 32; // Offset for drag handle size
        const endBound = isVerticalCaliper ? containerRect.width : containerRect.height;

        newPos = Math.max(startBound, Math.min(newPos, endBound));

        if (isVerticalCaliper) {
          caliper.style.left = `${newPos}px`;
        } else {
          caliper.style.top = `${newPos}px`;
        }

        updateCaliperValue(newPos, isVerticalCaliper, readout);
      }

      function onCaliperUp() {
        document.removeEventListener("mousemove", onCaliperMove);
        document.removeEventListener("touchmove", onCaliperMove);
        document.removeEventListener("mouseup", onCaliperUp);
        document.removeEventListener("touchend", onCaliperUp);
      }

      handle.addEventListener("mousedown", onCaliperDown as EventListener);
      handle.addEventListener("touchstart", onCaliperDown as EventListener, { passive: true });
    }

    setupCaliper(caliperH, true, rulerHContainer, caliperHReadout);
    setupCaliper(caliperV, false, rulerVContainer, caliperVReadout);
  }

  // Update physical measurement readout values for calipers
  function updateCaliperValue(pixelPosition: number, isHorizontalRuler: boolean, readout: HTMLElement | null) {
    if (!readout) return;

    // Deduct 32px because the 0 coordinate of the ruler scale starts after the drag handle
    const offsetPixels = pixelPosition - 32;
    
    let physicalValue = 0;
    let formattedText = "";

    if (unit === "px") {
      physicalValue = offsetPixels;
      formattedText = `${Math.round(physicalValue)} px`;
    } else if (unit === "cm") {
      physicalValue = offsetPixels / (ppi / 2.54);
      formattedText = `${physicalValue.toFixed(2)} cm`;
    } else if (unit === "mm") {
      physicalValue = offsetPixels / (ppi / 25.4);
      formattedText = `${physicalValue.toFixed(1)} mm`;
    } else if (unit === "in") {
      physicalValue = offsetPixels / ppi;
      
      if (showFractions) {
        formattedText = formatInchFractions(physicalValue);
      } else {
        formattedText = `${physicalValue.toFixed(2)} in`;
      }
    }

    readout.textContent = formattedText;
  }

  // Helper: Format decimal inches to common fractions (down to 1/16)
  function formatInchFractions(val: number): string {
    const whole = Math.floor(val);
    const fractionDec = val - whole;
    const sixteenths = Math.round(fractionDec * 16);

    if (sixteenths === 0) return `${whole} in`;
    if (sixteenths === 16) return `${whole + 1} in`;

    // Reduce fractions
    let numerator = sixteenths;
    let denominator = 16;
    while (numerator % 2 === 0 && denominator % 2 === 0) {
      numerator /= 2;
      denominator /= 2;
    }

    // Unicode fraction symbols for premium styling look
    const fractionGlyphs: { [key: string]: string } = {
      "1/2": "½", "1/4": "¼", "3/4": "¾",
      "1/8": "⅛", "3/8": "⅜", "5/8": "⅝", "7/8": "⅞"
    };

    const fractionStr = `${numerator}/${denominator}`;
    const glyph = fractionGlyphs[fractionStr] || ` ${numerator}/${denominator}`;
    const wholeStr = whole > 0 ? `${whole}` : "";

    return `${wholeStr}${glyph} in`;
  }

  // Forces calculation refreshes on active caliper values (on theme/unit/DPI shift)
  function updateCaliperCalculations() {
    const posH = parseInt(caliperH.style.left) || 200;
    const posV = parseInt(caliperV.style.top) || 200;
    updateCaliperValue(posH, true, caliperHReadout);
    updateCaliperValue(posV, false, caliperVReadout);
  }

  // UI Event Bindings
  function initControlListeners() {
    // Unit changes
    if (unitBtnGroup) {
      const buttons = unitBtnGroup.querySelectorAll("button");
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          unit = btn.getAttribute("data-unit") || "cm";
          localStorage.setItem("ruler_unit", unit);
          updateUIState();
          triggerRedraw();
          updateCaliperCalculations();
        });
      });
    }

    // Imperial fractional toggle
    if (fractionToggle) {
      fractionToggle.addEventListener("change", (e) => {
        showFractions = (e.target as HTMLInputElement).checked;
        localStorage.setItem("ruler_fractions", showFractions.toString());
        triggerRedraw();
        updateCaliperCalculations();
      });
    }

    // Global Lock / Unlock
    if (lockBtn) {
      lockBtn.addEventListener("click", toggleLockState);
    }

    // Fullscreen Mode
    if (fullscreenBtn) {
      fullscreenBtn.addEventListener("click", () => {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen().catch((err) => {
            console.error(`Error attempting to enable fullscreen: ${err.message}`);
          });
        } else {
          document.exitFullscreen();
        }
      });
    }

    // Reset Workspace Positions
    if (resetBtn) {
      resetBtn.addEventListener("click", resetRulerPositions);
    }

    // Window resizing handler
    window.addEventListener("resize", () => {
      triggerRedraw();
    });

    // Dark theme changes listener
    window.addEventListener("theme-change", () => {
      // Small timeout to allow styling variables to apply
      setTimeout(triggerRedraw, 50);
    });
  }

  // Lock Action handler
  function toggleLockState() {
    locked = !locked;
    if (workspace && lockIcon && lockText && lockBtn) {
      if (locked) {
        workspace.classList.add("locked");
        lockIcon.textContent = "🔒";
        lockText.textContent = "Unlock";
        lockBtn.classList.add("active");
        if (dragInstructions) {
          dragInstructions.innerHTML = `<p>🔒 Ruler Workspace is <strong>LOCKED</strong>. Place objects on screen safely without shifting elements.</p>`;
        }
      } else {
        workspace.classList.remove("locked");
        lockIcon.textContent = "🔓";
        lockText.textContent = "Lock";
        lockBtn.classList.remove("active");
        if (dragInstructions) {
          dragInstructions.innerHTML = `<p>🖱️ Drag Rulers to Position &bull; Use Caliper lines to measure exact boundaries &bull; Press <strong>L</strong> to lock</p>`;
        }
      }
    }
  }

  // Reset ruler alignments
  function resetRulerPositions() {
    rulerHContainer.style.top = "80px";
    rulerHContainer.style.left = "40px";
    rulerVContainer.style.top = "200px";
    rulerVContainer.style.left = "40px";
    
    caliperH.style.left = "200px";
    caliperV.style.top = "200px";

    updateCaliperCalculations();
  }

  // Keyboard Shortcuts Support
  function initKeyboardShortcuts() {
    document.addEventListener("keydown", (e) => {
      // Don't trigger shortcuts if user is typing inside configuration inputs
      const target = e.target as HTMLElement;
      if (target.tagName === "INPUT" || target.tagName === "SELECT") {
        return;
      }

      const key = e.key.toLowerCase();
      
      if (key === "l") {
        e.preventDefault();
        toggleLockState();
      } else if (key === "f") {
        e.preventDefault();
        fullscreenBtn?.click();
      } else if (key === "r") {
        e.preventDefault();
        resetRulerPositions();
      } else if (key === "c") {
        e.preventDefault();
        openModal();
      } else if (key === "u") {
        e.preventDefault();
        // Cycle units
        const units = ["cm", "mm", "in", "px"];
        let nextIdx = (units.indexOf(unit) + 1) % units.length;
        unit = units[nextIdx];
        localStorage.setItem("ruler_unit", unit);
        updateUIState();
        triggerRedraw();
        updateCaliperCalculations();
      }
    });
  }

  // Calibration Wizard Actions
  function initCalibrationModal() {
    // Open Modal
    if (calibrateBtn) calibrateBtn.addEventListener("click", openModal);
    
    // Close Modals
    if (modalCloseBtn) modalCloseBtn.addEventListener("click", closeModal);
    if (saveCloseBtn) saveCloseBtn.addEventListener("click", closeModal);
    
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });
    }

    // Modal Tabs logic
    const tabs = modal?.querySelectorAll(".tab-btn");
    tabs?.forEach(tab => {
      tab.addEventListener("click", () => {
        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        
        const targetPanelId = tab.getAttribute("data-tab");
        const panels = modal?.querySelectorAll(".tab-panel");
        panels?.forEach(panel => {
          if (panel.id === targetPanelId) {
            panel.classList.add("active");
          } else {
            panel.classList.remove("active");
          }
        });
      });
    });

    // Slider card calibration
    if (cardSlider && sliderPixelVal && virtualCard) {
      cardSlider.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        sliderPixelVal.textContent = `${val} pixels`;
        virtualCard.style.width = `${val}px`;
        
        // Calculate proportional height based on card outline aspect ratio (1.585)
        const height = Math.round(parseInt(val) / 1.585);
        virtualCard.style.height = `${height}px`;

        // Live calculate and update PPI
        const currentPpi = parseInt(val) / CARD_WIDTH_INCH;
        savePPI(currentPpi);
      });
    }

    // Manual Diagonal Specification Form Calculation
    if (calcDiagonalBtn) {
      calcDiagonalBtn.addEventListener("click", () => {
        const diagonal = parseFloat(diagonalInput.value);
        const w = parseInt(resWidthInput.value);
        const h = parseInt(resHeightInput.value);

        if (diagonal > 0 && w > 0 && h > 0) {
          const pixelDiagonal = Math.sqrt(w*w + h*h);
          const computedPpi = pixelDiagonal / diagonal;
          savePPI(computedPpi);
          alert(`Calibration Applied! Calculated Resolution Density: ${Math.round(computedPpi * 100) / 100} PPI.`);
        } else {
          alert("Please enter valid numeric specifications.");
        }
      });
    }

    // Direct PPI Entry Form
    if (applyPpiBtn) {
      applyPpiBtn.addEventListener("click", () => {
        const manualPpi = parseFloat(manualPpiInput.value);
        if (manualPpi >= 30 && manualPpi <= 600) {
          savePPI(manualPpi);
          alert(`Calibration Applied! Set to ${manualPpi} PPI.`);
        } else {
          alert("Please enter a valid PPI value between 30 and 600.");
        }
      });
    }
  }

  function openModal() {
    if (modal) {
      modal.classList.add("active");
      
      // Update slider input value to current PPI equivalent
      const pixelWidth = Math.round(ppi * CARD_WIDTH_INCH);
      if (cardSlider) {
        cardSlider.value = pixelWidth.toString();
        cardSlider.dispatchEvent(new Event("input"));
      }
    }
  }

  function closeModal() {
    if (modal) modal.classList.remove("active");
  }

  // Initialize
  document.addEventListener("DOMContentLoaded", () => {
    loadSettings();
    initDragHandlers();
    initCaliperHandlers();
    initControlListeners();
    initKeyboardShortcuts();
    initCalibrationModal();
  });
</script>
