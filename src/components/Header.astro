---
import { siteConfig } from "../config";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="main-header glass">
  <div class="container nav-container">
    <a href="/" class="brand-link">
      <span class="logo-emoji">⚡</span>
      <span class="logo-text">{siteConfig.name}</span>
    </a>
    
    <nav class="nav-links" aria-label="Main Navigation">
      <a href="/" class="nav-link active">Tool</a>
      <a href="https://github.com/manish" target="_blank" rel="noopener noreferrer" class="nav-link github-link">
        GitHub
      </a>
    </nav>

    <div class="actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .main-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    display: flex;
    align-items: center;
    border-bottom: 1px solid hsla(var(--border-color-hsl), 0.4);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.25rem;
    color: hsl(var(--text-primary-hsl));
    letter-spacing: -0.01em;
    transition: var(--transition-quick);
  }

  .brand-link:hover {
    color: hsl(var(--accent-hsl));
  }

  .logo-emoji {
    font-size: 1.4rem;
  }

  .logo-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: hsl(var(--text-secondary-hsl));
    position: relative;
    padding: 6px 0;
  }

  .nav-link:hover {
    color: hsl(var(--text-primary-hsl));
  }

  .nav-link.active {
    color: hsl(var(--accent-hsl));
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 2px;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 600px) {
    .nav-links {
      display: none; /* Keep it ultra simple, hide secondary links on mobile */
    }
  }
</style>
