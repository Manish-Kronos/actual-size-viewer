---
/**
 * ActualSizeViewer — The core rendering engine component.
 *
 * Renders any ActualSizeObject at its true physical size using CSS calc()
 * driven by the --dpi CSS custom property set by calibration-engine.ts.
 *
 * ZERO JavaScript inside this component.
 * All reactivity comes from the CSS variable --dpi on :root.
 *
 * CSS formula:
 *   width  = calc(var(--obj-w-mm) / 25.4 * var(--dpi, 96) * 1px)
 *   height = calc(var(--obj-h-mm) / 25.4 * var(--dpi, 96) * 1px)
 */
import type { ActualSizeObject } from "../../data/schema";
import { mmToIn, round } from "../../lib/rendering";

interface Props {
  object: ActualSizeObject;
  /** Show object name + dimensions beneath the rendered object */
  showLabel?: boolean;
  /** Show mm ruler tick marks along top and left edges */
  showRulerOverlay?: boolean;
  /** Additional CSS class on the viewer wrapper */
  class?: string;
}

const {
  object,
  showLabel = true,
  showRulerOverlay = false,
  class: className = "",
} = Astro.props;

const { widthMm, heightMm, shape, depthMm } = object.dimensions;
const { color, borderColor, image, imageAlt } = object.display;

// Shape → border radius CSS value
const borderRadius: Record<string, string> = {
  rect:   "6px",
  circle: "50%",
  oval:   "50% / 40%",
};
const radius = borderRadius[shape] ?? "6px";

// The inline style drives the CSS calc() — these vars are consumed by .asv-object
const objectStyle = [
  `--obj-w-mm: ${widthMm}`,
  `--obj-h-mm: ${heightMm}`,
  `--obj-color: ${color}`,
  `--obj-border: ${borderColor ?? color}`,
  `--obj-radius: ${radius}`,
].join("; ");

// Label dimensions
const isCircle = shape === "circle";
const widthLabel  = isCircle ? `⌀ ${round(widthMm, 2)} mm` : `${round(widthMm, 2)} mm`;
const heightLabel = isCircle ? "" : `× ${round(heightMm, 2)} mm`;
const inchLabel   = isCircle
  ? `(${mmToIn(widthMm)} in)`
  : `(${mmToIn(widthMm)} × ${mmToIn(heightMm)} in)`;
---

<div class:list={["asv-wrapper", className]}>
  <!-- The object rendered at actual physical size -->
  <div
    class:list={["asv-object", { "asv-object--has-image": !!image, "asv-object--ruler": showRulerOverlay }]}
    style={objectStyle}
    role="img"
    aria-label={`${object.name} at actual size — ${widthMm} × ${heightMm} mm`}
  >
    {image && (
      <img
        src={image}
        alt={imageAlt ?? `${object.name} at actual size`}
        class="asv-object__image"
        loading="lazy"
        decoding="async"
        width={Math.round(widthMm * 3.78)}
        height={Math.round(heightMm * 3.78)}
      />
    )}
    {!image && (
      <span class="asv-object__fallback-label">{object.name}</span>
    )}
  </div>

  {showLabel && (
    <div class="asv-label">
      <span class="asv-label__name">{object.name}</span>
      <span class="asv-label__dims">{widthLabel}{heightLabel} <span class="asv-label__dims-in">{inchLabel}</span></span>
    </div>
  )}
</div>

<style>
  /* ── Wrapper ─────────────────────────────────────────────── */
  .asv-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  /* ── The rendered object ─────────────────────────────────── */
  .asv-object {
    /*
     * THE rendering formula.
     * --dpi is set on :root by calibration-engine.ts.
     * Changing --dpi instantly resizes every object on the page.
     * No JS re-render needed.
     */
    width:  calc(var(--obj-w-mm) / 25.4 * var(--dpi, 96) * 1px);
    height: calc(var(--obj-h-mm) / 25.4 * var(--dpi, 96) * 1px);

    background-color: var(--obj-color);
    border: 2px solid var(--obj-border);
    border-radius: var(--obj-radius);
    box-shadow:
      0 2px 8px rgba(0,0,0,0.12),
      inset 0 1px 0 rgba(255,255,255,0.08);

    position: relative;
    overflow: hidden;
    flex-shrink: 0;

    /* Smooth resize when DPI changes — feels live */
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Image fill ──────────────────────────────────────────── */
  .asv-object__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Fallback text when no image ─────────────────────────── */
  .asv-object__fallback-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.6rem, 2cqi, 0.85rem);
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 4px;
    pointer-events: none;
  }

  /* ── Ruler overlay tick marks ────────────────────────────── */
  .asv-object--ruler::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background-image: repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.6) 0px,
      rgba(255,255,255,0.6) 1px,
      transparent 1px,
      /* tick every mm: calc(1mm * px-per-mm) */
      transparent calc(var(--dpi, 96) / 25.4 * 1px)
    );
    pointer-events: none;
  }

  /* ── Label ───────────────────────────────────────────────── */
  .asv-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .asv-label__name {
    font-weight: 600;
    font-size: 0.95rem;
    color: hsl(var(--text-primary-hsl));
  }

  .asv-label__dims {
    font-size: 0.82rem;
    font-weight: 500;
    color: hsl(var(--text-secondary-hsl));
  }

  .asv-label__dims-in {
    opacity: 0.65;
  }
</style>
