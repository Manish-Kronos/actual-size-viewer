---
import { siteConfig } from "../config";
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="container footer-container">
    <div class="footer-brand">
      <p class="brand-title">{siteConfig.name}</p>
      <p class="brand-desc">{siteConfig.shortDescription}</p>
    </div>
    
    <div class="footer-meta">
      <p class="copyright">
        &copy; {currentYear} {siteConfig.author}. All rights reserved.
      </p>
      <div class="meta-links">
        <a href="#" class="meta-link">Privacy Policy</a>
        <span class="separator">&bull;</span>
        <a href="#" class="meta-link">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    margin-top: auto;
    background-color: hsl(var(--bg-secondary-hsl));
    border-top: 1px solid hsl(var(--border-color-hsl));
    padding: 40px 0 30px;
    font-size: 0.9rem;
    transition: var(--transition-smooth);
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-title {
    font-weight: 700;
    color: hsl(var(--text-primary-hsl));
    font-size: 1.1rem;
  }

  .brand-desc {
    font-size: 0.85rem;
    color: hsl(var(--text-secondary-hsl));
  }

  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid hsla(var(--border-color-hsl), 0.6);
    padding-top: 20px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .copyright {
    color: hsl(var(--text-secondary-hsl));
  }

  .meta-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .meta-link {
    color: hsl(var(--text-secondary-hsl));
    font-size: 0.85rem;
    transition: var(--transition-quick);
  }

  .meta-link:hover {
    color: hsl(var(--accent-hsl));
  }

  .separator {
    color: hsl(var(--border-color-hsl));
    font-size: 0.6rem;
  }

  @media (max-width: 600px) {
    .footer-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
