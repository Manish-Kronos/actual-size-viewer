## 1. Object Data Structure

### Design Principles
- **Canonical unit = millimeters.** Every object stores dimensions in `mm`. The engine converts to pixels at render time. No unit ambiguity, ever.
- **One JSON file per category.** Easy to add, diff, and review in Git.
- **Every field is typed.** A TypeScript schema validates data at build time.

### TypeScript Schema

```typescript
// src/data/schema.ts

export type ObjectShape = "rect" | "circle" | "oval";
export type ObjectCategory =
  | "coins" | "credit-cards" | "paper" | "phones"
  | "monitors" | "lumber" | "keys" | "cards";

export interface ObjectDimensions {
  widthMm: number;       // physical width in millimeters
  heightMm: number;      // physical height in millimeters
  shape: ObjectShape;    // determines border-radius logic
  depthMm?: number;      // optional, for reference only (not rendered)
}

export interface ObjectDisplay {
  color: string;          // "#c0c0c0" — fill when no image
  borderColor?: string;   // outline color
  image?: string;         // "/images/objects/coins/us-quarter.webp"
  imageAlt?: string;
  showRulerOverlay?: boolean;  // draws tick marks on rendered object
}

export interface ObjectMeta {
  title: string;          // "US Quarter Actual Size"
  description: string;    // ~155 chars for meta description
  h1: string;             // "US Quarter — See It at Actual Size"
  facts: string[];        // 3–5 bullet facts shown on object page
  relatedSlugs: string[]; // slugs of related objects for internal links
  source?: string;        // citation URL for the dimensions
  updatedAt: string;      // ISO date "2025-01-15"
}

export interface ActualSizeObject {
  id: string;             // "us-quarter" — globally unique
  slug: string;           // "us-quarter" — matches id, used in URL
  name: string;           // "US Quarter"
  category: ObjectCategory;
  tags: string[];
  dimensions: ObjectDimensions;
  display: ObjectDisplay;
  meta: ObjectMeta;
}

export interface Category {
  id: ObjectCategory;
  slug: string;
  name: string;
  icon: string;           // single emoji
  description: string;    // 1–2 sentences
  metaTitle: string;
  metaDescription: string;
}
```

